# Documented larger run (NOT the committed result).
#
# This is a documented configuration, not a claimed result. It trades CPU time
# for a wider, longer-trained network on more synthetic frames. To reproduce it,
# raise the dataset sizes in src/constellation_vision/config.py (N_TRAIN / N_TEST)
# or override them in code, then:
#   set -a; source configs/train.large.env; set +a; make train
#
# On a multi-core CPU this takes considerably longer than the default run; on a
# single GPU box it is fast. The headline you publish must be whatever THIS run
# actually reports on the held-out split, regenerated by the command above.

CV_EPOCHS=40
CV_BATCH_SIZE=32
CV_LR=8e-4
CV_BASE_WIDTH=32
CV_MIN_MEAN_IOU=0.75
