# Default training configuration for `make train` (the committed run).
# Every value is also a config.py default; this file documents them in one place
# and can be sourced to reproduce the committed number on a clean CPU box:
#   set -a; source configs/train.default.env; set +a; make train
#
# These settings train a compact UNet-lite from scratch to the committed
# held-out mean IoU in a few minutes on a laptop CPU.

CV_EPOCHS=16
CV_BATCH_SIZE=16
CV_LR=1e-3
CV_BASE_WIDTH=16
CV_MIN_MEAN_IOU=0.75
